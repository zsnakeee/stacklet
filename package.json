{
  "name": "stacklet",
  "version": "0.1.0",
  "description": "Stacklet — local Laravel dev stack for Windows (nginx, PHP, MySQL, .test HTTPS)",
  "author": "zsnakeee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zsnakeee/stacklet.git"
  },
  "bugs": {
    "url": "https://github.com/zsnakeee/stacklet/issues"
  },
  "homepage": "https://github.com/zsnakeee/stacklet#readme",
  "keywords": [
    "laravel",
    "windows",
    "electron",
    "nginx",
    "php",
    "local-development",
    "dev-environment"
  ],
  "main": "dist/main/index.js",
  "bin": {
    "devmgr": "dist/cli/index.js"
  },
  "scripts": {
    "prestart": "npm run build",
    "start": "electron .",
    "build": "tsc && node scripts/copy-renderer.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "devmgr": "npm run build && node dist/cli/index.js",
    "spike": "npm run build && node dist/spike/index.js",
    "helper": "npm run build && node dist/helper/server.js",
    "dev": "ts-node src/main/index.ts",
    "predist": "node scripts/release-pack-lock.mjs",
    "prepack": "node scripts/release-pack-lock.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "node-forge": "^1.3.1",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "@vitest/coverage-v8": "^4.1.7",
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "com.stacklet.app",
    "productName": "Stacklet",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "dist/renderer",
        "to": "renderer"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
