{
  "name": "stacklet",
  "version": "0.1.0",
  "description": "Stacklet — local Laravel dev stack for Windows (nginx, PHP, MySQL, .test HTTPS)",
  "author": "zsnakeee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zsnakeee/stacklet.git"
  },
  "bugs": {
    "url": "https://github.com/zsnakeee/stacklet/issues"
  },
  "homepage": "https://github.com/zsnakeee/stacklet#readme",
  "keywords": [
    "laravel",
    "windows",
    "electron",
    "nginx",
    "php",
    "local-development",
    "dev-environment"
  ],
  "main": "dist/main/index.js",
  "bin": {
    "devmgr": "dist/cli/index.js"
  },
  "scripts": {
    "prestart": "npm run build",
    "start": "electron .",
    "build": "tsc && vite build",
    "build:renderer": "vite build",
    "icon": "node scripts/gen-icon.mjs",
    "dev:renderer": "vite",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/renderer/tsconfig.json",
    "test": "vitest run",
    "devmgr": "npm run build && node dist/cli/index.js",
    "spike": "npm run build && node dist/spike/index.js",
    "helper": "npm run build && node dist/helper/server.js",
    "dev": "ts-node src/main/index.ts",
    "predist": "node scripts/release-pack-lock.mjs",
    "prepack": "node scripts/release-pack-lock.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "globe.gl": "^2.46.1",
    "gsap": "^3.15.0",
    "motion": "^12.40.0",
    "node-forge": "^1.3.1",
    "ogl": "^1.0.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "smol-toml": "^1.6.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "com.stacklet.app",
    "productName": "Stacklet",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "dist/renderer",
        "to": "renderer"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
